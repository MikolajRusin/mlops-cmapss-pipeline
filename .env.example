# --- PostgreSQL ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_MULTIPLE_DATABASES=mlflow_db,dagster_db

# --- MinIO (local S3-compatible object store) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123

# --- MLflow ---
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_POSTGRES_DB=mlflow_db
EXPERIMENT_NAME=CMAPSS
MODEL_NAME=cmapss-rul-predictor

# --- Evidently AI (obtain from https://app.evidently.cloud) ---
EVIDENTLY_AI_URL=https://app.evidently.cloud
EVIDENTLY_AI_API_KEY=your_evidently_api_key
EVIDENTLY_AI_ORG_ID=your_evidently_org_id
EVIDENTLY_AI_PROJECT_ID=your_evidently_project_id

# --- Dagster ---
DAGSTER_POSTGRES_DB=dagster_db